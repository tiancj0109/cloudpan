<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.cloudpan.mapper.OssConfigMapper">
    <resultMap id="BaseResultMap" type="com.cloudpan.entity.OssConfig">
        <id column="id" property="id" jdbcType="INTEGER"/>
        <result column="provider" property="provider" jdbcType="VARCHAR"/>
        <result column="endpoint" property="endpoint" jdbcType="VARCHAR"/>
        <result column="access_key" property="accessKey" jdbcType="VARCHAR"/>
        <result column="secret_key" property="secretKey" jdbcType="VARCHAR"/>
        <result column="bucket_name" property="bucketName" jdbcType="VARCHAR"/>
        <result column="is_enable" property="isEnable" jdbcType="INTEGER"/>
    </resultMap>

    <select id="findFirst" resultMap="BaseResultMap">
        SELECT * FROM oss_config LIMIT 1
    </select>
    
    <insert id="insert" parameterType="com.cloudpan.entity.OssConfig">
        INSERT INTO oss_config (provider, endpoint, access_key, secret_key, bucket_name, is_enable, created_at)
        VALUES (#{provider}, #{endpoint}, #{accessKey}, #{secretKey}, #{bucketName}, 1, NOW())
    </insert>
    
    <update id="update" parameterType="com.cloudpan.entity.OssConfig">
        UPDATE oss_config
        SET provider = #{provider}, endpoint = #{endpoint}, access_key = #{accessKey}, 
            secret_key = #{secretKey}, bucket_name = #{bucketName}, updated_at = NOW()
        WHERE id = #{id}
    </update>
</mapper>
