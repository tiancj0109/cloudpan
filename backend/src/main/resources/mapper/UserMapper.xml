<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.cloudpan.mapper.UserMapper">
    <resultMap id="BaseResultMap" type="com.cloudpan.entity.User">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="avatar" property="avatar" jdbcType="VARCHAR"/>
        <result column="role" property="role" jdbcType="VARCHAR"/>
        <result column="signature" property="signature" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
        <result column="last_moments_read_at" property="lastMomentsReadAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, password, email, avatar, role, signature, status, created_at, updated_at, last_moments_read_at
    </sql>

    <insert id="insert" parameterType="com.cloudpan.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, email, role, signature, status, created_at, updated_at, last_moments_read_at)
        VALUES (#{username}, #{password}, #{email}, #{role}, #{signature}, #{status}, NOW(), NOW(), #{lastMomentsReadAt})
    </insert>

    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE username = #{username}
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE id = #{id}
    </select>

    <select id="searchUsers" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE username LIKE CONCAT('%', #{keyword}, '%')
           OR email LIKE CONCAT('%', #{keyword}, '%')
           OR CAST(id AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
    </select>
    
    <update id="update" parameterType="com.cloudpan.entity.User">
        UPDATE user
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="email != null">email = #{email},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="signature != null">signature = #{signature},</if>
            <if test="status != null">status = #{status},</if>
            <if test="lastMomentsReadAt != null">last_moments_read_at = #{lastMomentsReadAt},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>
    <update id="updateLastMomentsReadAt">
        UPDATE user
        SET last_moments_read_at = NOW()
        WHERE id = #{id}
    </update>
</mapper>
